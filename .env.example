# ─── Supabase ─────────────────────────────────────────────────────────────────
# Settings → API in your Supabase dashboard (MaintainX Project)
SUPABASE_URL=https://spavmunneesbihkdjzgp.supabase.co
SUPABASE_SERVICE_ROLE_KEY=    # Settings → API → service_role (keep secret)

# Tenant — which public.orgs.id CountLock belongs to
COUNTLOCK_ORG_ID=cae14322-1b10-408f-8307-138b7850a945   # UPI Manufacturing

# ─── Roboflow ─────────────────────────────────────────────────────────────────
# Leave blank and set MOCK_COUNT=true to skip Roboflow during local testing
ROBOFLOW_MODEL_URL=    # https://detect.roboflow.com/YOUR_PROJECT/YOUR_VERSION
ROBOFLOW_API_KEY=
COUNT_CONFIDENCE_THRESHOLD=0.65

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
SUPERVISOR_EMAIL=supervisor@example.com
FROM_EMAIL=CountLock <countlock@yourdomain.com>

# ─── Local dev ────────────────────────────────────────────────────────────────
# true  → skip Roboflow, return a random count (fast UI testing)
# false → hit Roboflow (requires ROBOFLOW_MODEL_URL + ROBOFLOW_API_KEY)
MOCK_COUNT=true
